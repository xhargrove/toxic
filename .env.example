# Pooled connection for Prisma runtime (often Supabase pooler + pgbouncer)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Optional copy for scripts/docs — not read by Prisma schema (use a direct Postgres
# `DATABASE_URL` when running `prisma migrate` against Supabase if the pooler URL fails).
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Public — safe for browser bundle (see lib/supabase/browser.ts)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — never expose to the client or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
