# Pooled connection for the app (Supabase pooler :6543 or local).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Direct Postgres URL for Prisma Migrate / introspection. Required by `schema.prisma`.
# · Local: same as DATABASE_URL above.
# · Supabase: use "Direct connection" / port 5432 from the dashboard — not the pooler URL.
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Public — safe for browser bundle (see lib/supabase/browser.ts)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — never expose to the client or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
